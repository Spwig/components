{
  "colors": {
    "primary": "#d4af37",
    "primary-hover": "#b8941f",
    "primary-light": "#f5e6b8",
    "secondary": "#2c2c2c",
    "secondary-hover": "#1a1a1a",
    "accent": "#8b7355",
    "accent-hover": "#6d5a43",
    "text": "#2c2c2c",
    "text-light": "#5a5a5a",
    "text-muted": "#9e9e9e",
    "text-inverse": "#ffffff",
    "background": "#fafafa",
    "background-alt": "#f5f5f5",
    "surface": "#ffffff",
    "surface-hover": "#f0f0f0",
    "border": "#e8e8e8",
    "border-light": "#f0f0f0",
    "border-dark": "#d0d0d0",
    "success": "#4a7c59",
    "success-light": "#d4e5d9",
    "error": "#a94442",
    "error-light": "#f2dede",
    "warning": "#c9a55b",
    "warning-light": "#fcf8e3",
    "info": "#5a7a98",
    "info-light": "#d9edf7",
    "overlay": "rgba(0, 0, 0, 0.5)"
  },
  "typography": {
    "font-sans": "Inter, system-ui, -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif",
    "font-serif": "Playfair Display, Georgia, 'Times New Roman', serif",
    "font-mono": "ui-monospace, SFMono-Regular, 'SF Mono', Menlo, Consolas, monospace",
    "font-size-xs": "0.75rem",
    "font-size-sm": "0.875rem",
    "font-size-base": "1rem",
    "font-size-lg": "1.125rem",
    "font-size-xl": "1.5rem",
    "font-size-2xl": "2rem",
    "font-size-3xl": "2.5rem",
    "font-size-4xl": "3rem",
    "font-size-5xl": "3.75rem",
    "font-weight-normal": "400",
    "font-weight-medium": "500",
    "font-weight-semibold": "600",
    "font-weight-bold": "700",
    "line-height-tight": "1.3",
    "line-height-normal": "1.6",
    "line-height-relaxed": "1.75",
    "letter-spacing-tight": "-0.01em",
    "letter-spacing-normal": "0",
    "letter-spacing-wide": "0.05em"
  },
  "spacing": {
    "0": "0",
    "1": "0.25rem",
    "2": "0.5rem",
    "3": "0.75rem",
    "4": "1rem",
    "5": "1.25rem",
    "6": "1.5rem",
    "8": "2rem",
    "10": "2.5rem",
    "12": "3rem",
    "16": "4rem",
    "20": "5rem",
    "24": "6rem"
  },
  "borders": {
    "width-0": "0",
    "width-1": "1px",
    "width-2": "2px",
    "radius-none": "0",
    "radius-sm": "0.125rem",
    "radius-base": "0.25rem",
    "radius-md": "0.375rem",
    "radius-lg": "0.5rem",
    "radius-xl": "0.75rem",
    "radius-full": "9999px"
  },
  "shadows": {
    "none": "none",
    "sm": "0 1px 2px 0 rgba(0, 0, 0, 0.05)",
    "base": "0 1px 3px 0 rgba(0, 0, 0, 0.08), 0 1px 2px -1px rgba(0, 0, 0, 0.08)",
    "md": "0 4px 6px -1px rgba(0, 0, 0, 0.08), 0 2px 4px -2px rgba(0, 0, 0, 0.08)",
    "lg": "0 10px 15px -3px rgba(0, 0, 0, 0.08), 0 4px 6px -4px rgba(0, 0, 0, 0.08)",
    "xl": "0 20px 25px -5px rgba(0, 0, 0, 0.1), 0 8px 10px -6px rgba(0, 0, 0, 0.1)"
  },
  "transitions": {
    "duration-fast": "200ms",
    "duration-base": "300ms",
    "duration-slow": "400ms",
    "easing-default": "cubic-bezier(0.4, 0, 0.2, 1)",
    "easing-in": "cubic-bezier(0.4, 0, 1, 1)",
    "easing-out": "cubic-bezier(0, 0, 0.2, 1)"
  },
  "breakpoints": {
    "sm": "640px",
    "md": "768px",
    "lg": "1024px",
    "xl": "1280px",
    "2xl": "1536px"
  },
  "z-index": {
    "dropdown": "1000",
    "sticky": "1020",
    "fixed": "1030",
    "modal-backdrop": "1040",
    "modal": "1050",
    "popover": "1060",
    "tooltip": "1070"
  },
  "container": {
    "max-width": "1200px",
    "padding": "1.5rem"
  },
  "menu": {
    "text-color": "var(--color-text)",
    "text-hover-color": "var(--color-text-inverse)",
    "background": "transparent",
    "background-hover": "var(--color-primary)",
    "dropdown-background": "var(--color-surface)",
    "dropdown-shadow": "var(--shadow-lg)",
    "border-color": "var(--color-border)",
    "active-indicator-color": "var(--color-primary)",
    "item-gap": { "mobile": "0", "desktop": "var(--space-1)" },
    "link-padding-x": { "mobile": "var(--space-3)", "desktop": "var(--space-4)" },
    "link-padding-y": "var(--space-2)",
    "dropdown-padding": "var(--space-2)",
    "dropdown-offset": "var(--space-2)",
    "font-size": { "mobile": "var(--font-size-sm)", "desktop": "var(--font-size-base)" },
    "font-weight": "var(--font-weight-medium)",
    "font-weight-active": "var(--font-weight-semibold)",
    "border-radius": "var(--radius-md)",
    "dropdown-border-radius": "var(--radius-lg)",
    "animation-duration": "var(--duration-fast)",
    "animation-timing": "var(--easing-default)",
    "slide-duration": "var(--duration-slow)"
  },
  "elements": {
    "form": {
      "input-bg": "var(--color-surface)",
      "input-border": "var(--color-border)",
      "input-focus-border": "var(--color-primary)",
      "input-radius": "var(--radius-md)",
      "input-padding": "var(--space-3)",
      "input-disabled-bg": "var(--color-background-alt)",
      "input-placeholder-color": "var(--color-text-muted)",
      "label-color": "var(--color-text)",
      "label-size": "var(--font-size-sm)",
      "error-color": "var(--color-error)",
      "help-color": "var(--color-text-muted)",
      "primary-color": "var(--color-primary)",
      "primary-hover": "var(--color-primary-hover)",
      "success-color": "var(--color-success)",
      "warning-color": "var(--color-warning)",
      "text-color": "var(--color-text)",
      "text-muted": "var(--color-text-muted)",
      "bg-color": "var(--color-surface)",
      "bg-light": "var(--color-background-alt)",
      "border-color": "var(--color-border)",
      "focus-shadow": "0 0 0 3px var(--color-primary-light)",
      "title-size": "var(--font-size-xl)",
      "heading-size": "var(--font-size-lg)",
      "base-size": "var(--font-size-base)",
      "small-size": "var(--font-size-sm)",
      "tiny-size": "var(--font-size-xs)",
      "font-weight-bold": "var(--font-weight-semibold)",
      "font-weight-medium": "var(--font-weight-medium)",
      "line-height-relaxed": "var(--line-height-relaxed)",
      "spacing-lg": "var(--space-6)",
      "spacing-md": "var(--space-4)",
      "spacing-sm": "var(--space-3)",
      "spacing-xs": "var(--space-2)",
      "container-max-width": "720px",
      "container-padding": "var(--space-6)",
      "shadow": "var(--shadow-sm)",
      "transition": "all 0.2s ease",
      "button-padding-x": "var(--space-6)",
      "button-padding-y": "var(--space-3)",
      "button-radius": "var(--radius-md)",
      "checkbox-size": "1.25rem",
      "checkbox-radius": "var(--radius-sm)",
      "radio-size": "1.25rem",
      "star-empty-color": "var(--color-border)",
      "star-filled-color": "var(--color-primary)",
      "nps-button-height": "48px",
      "likert-min-width": "80px",
      "progress-height": "8px",
      "step-circle-size": "36px",
      "step-circle-size-mobile": "32px"
    }
  }
}
