{
  "colors": {
    "primary": "#e11d48",
    "primary-hover": "#be123c",
    "primary-light": "#fecdd3",
    "secondary": "#d946ef",
    "secondary-hover": "#c026d3",
    "accent": "#f59e0b",
    "accent-hover": "#d97706",
    "text": "#292524",
    "text-light": "#57534e",
    "text-muted": "#a8a29e",
    "text-inverse": "#ffffff",
    "background": "#fff7ed",
    "background-alt": "#ffedd5",
    "surface": "#ffffff",
    "surface-hover": "#fef3c7",
    "border": "#e7e5e4",
    "border-light": "#f5f5f4",
    "border-dark": "#d6d3d1",
    "success": "#10b981",
    "success-light": "#d1fae5",
    "error": "#dc2626",
    "error-light": "#fee2e2",
    "warning": "#f59e0b",
    "warning-light": "#fef3c7",
    "info": "#3b82f6",
    "info-light": "#dbeafe",
    "overlay": "rgba(0, 0, 0, 0.5)"
  },
  "typography": {
    "font-sans": "Lato, Inter, system-ui, -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif",
    "font-serif": "Cormorant Garamond, Georgia, 'Times New Roman', serif",
    "font-mono": "ui-monospace, SFMono-Regular, 'SF Mono', Menlo, Consolas, monospace",
    "font-size-xs": "0.75rem",
    "font-size-sm": "0.875rem",
    "font-size-base": "1rem",
    "font-size-lg": "1.125rem",
    "font-size-xl": "1.375rem",
    "font-size-2xl": "1.75rem",
    "font-size-3xl": "2.25rem",
    "font-size-4xl": "2.75rem",
    "font-size-5xl": "3.5rem",
    "font-weight-normal": "400",
    "font-weight-medium": "500",
    "font-weight-semibold": "600",
    "font-weight-bold": "700",
    "line-height-tight": "1.3",
    "line-height-normal": "1.625",
    "line-height-relaxed": "1.75",
    "letter-spacing-tight": "-0.025em",
    "letter-spacing-normal": "0",
    "letter-spacing-wide": "0.05em"
  },
  "spacing": {
    "0": "0",
    "1": "0.25rem",
    "2": "0.5rem",
    "3": "0.75rem",
    "4": "1rem",
    "5": "1.25rem",
    "6": "1.5rem",
    "8": "2rem",
    "10": "2.5rem",
    "12": "3rem",
    "16": "4rem",
    "20": "5rem",
    "24": "6rem"
  },
  "borders": {
    "width-0": "0",
    "width-1": "1px",
    "width-2": "2px",
    "radius-none": "0",
    "radius-sm": "0.25rem",
    "radius-base": "0.5rem",
    "radius-md": "0.625rem",
    "radius-lg": "0.75rem",
    "radius-xl": "1rem",
    "radius-full": "9999px"
  },
  "shadows": {
    "none": "none",
    "sm": "0 1px 2px 0 rgba(0, 0, 0, 0.04)",
    "base": "0 2px 4px 0 rgba(0, 0, 0, 0.06), 0 1px 2px -1px rgba(0, 0, 0, 0.06)",
    "md": "0 4px 8px -1px rgba(0, 0, 0, 0.08), 0 2px 4px -2px rgba(0, 0, 0, 0.08)",
    "lg": "0 8px 16px -2px rgba(0, 0, 0, 0.1), 0 4px 6px -4px rgba(0, 0, 0, 0.1)",
    "xl": "0 16px 32px -4px rgba(0, 0, 0, 0.12), 0 8px 10px -6px rgba(0, 0, 0, 0.12)"
  },
  "transitions": {
    "duration-fast": "200ms",
    "duration-base": "300ms",
    "duration-slow": "500ms",
    "easing-default": "cubic-bezier(0.4, 0, 0.2, 1)",
    "easing-in": "cubic-bezier(0.4, 0, 1, 1)",
    "easing-out": "cubic-bezier(0, 0, 0.2, 1)"
  },
  "breakpoints": {
    "sm": "640px",
    "md": "768px",
    "lg": "1024px",
    "xl": "1280px",
    "2xl": "1536px"
  },
  "z-index": {
    "dropdown": "1000",
    "sticky": "1020",
    "fixed": "1030",
    "modal-backdrop": "1040",
    "modal": "1050",
    "popover": "1060",
    "tooltip": "1070"
  },
  "container": {
    "max-width": "1280px",
    "padding": "1rem"
  },
  "header": {
    "background": "var(--color-surface)",
    "border-color": "var(--color-border)",
    "text-color": "var(--color-text)",
    "icon-color": "var(--color-text-light)",
    "icon-hover-color": "var(--color-primary)",
    "link-color": "var(--color-text)",
    "link-hover-color": "var(--color-primary)",
    "logo-height": "40px",
    "padding-x": "var(--space-4)",
    "padding-y": "var(--space-4)",
    "announcement-bg": "var(--color-primary)",
    "announcement-text-color": "var(--color-text-inverse)",
    "zones": {
      "top-bar": {
        "background": "var(--color-background-alt)",
        "text-color": "var(--color-text-light)",
        "border-color": "var(--color-border)",
        "font-size": "var(--font-size-sm)",
        "height": "36px",
        "padding-y": "var(--space-2)"
      },
      "main-header": {
        "background": "var(--color-surface)",
        "text-color": "var(--color-text)",
        "border-color": "var(--color-border)",
        "height": "70px",
        "padding-y": "var(--space-4)"
      },
      "bottom-bar": {
        "background": "var(--color-background-alt)",
        "text-color": "var(--color-text)",
        "border-color": "var(--color-border)",
        "font-size": "var(--font-size-sm)",
        "height": "50px",
        "padding-y": "var(--space-3)"
      }
    }
  },
  "footer": {
    "background": "#292524",
    "border-color": "rgba(255, 255, 255, 0.1)",
    "text-color": "rgba(255, 255, 255, 0.85)",
    "heading-color": "#ffffff",
    "link-color": "rgba(255, 255, 255, 0.7)",
    "link-hover-color": "var(--color-primary-light)",
    "muted-color": "rgba(255, 255, 255, 0.5)",
    "padding-y": "var(--space-12)",
    "column-gap": "var(--space-8)",
    "zones": {
      "top": {
        "background": "transparent",
        "text-color": "rgba(255, 255, 255, 0.85)",
        "border-color": "rgba(255, 255, 255, 0.1)",
        "padding-y": "var(--space-12)"
      },
      "main": {
        "background": "transparent",
        "text-color": "rgba(255, 255, 255, 0.85)",
        "padding-y": "var(--space-8)"
      },
      "bottom": {
        "background": "rgba(0, 0, 0, 0.2)",
        "text-color": "rgba(255, 255, 255, 0.6)",
        "border-color": "rgba(255, 255, 255, 0.1)",
        "padding-y": "var(--space-4)",
        "font-size": "var(--font-size-sm)"
      }
    }
  },
  "menu": {
    "text-color": "var(--color-text)",
    "text-hover-color": "var(--color-text-inverse)",
    "background": "transparent",
    "background-hover": "var(--color-primary)",
    "dropdown-background": "var(--color-surface)",
    "dropdown-shadow": "var(--shadow-lg)",
    "border-color": "var(--color-border)",
    "active-indicator-color": "var(--color-primary)",
    "item-gap": { "mobile": "0", "desktop": "var(--space-1)" },
    "link-padding-x": { "mobile": "var(--space-3)", "desktop": "var(--space-4)" },
    "link-padding-y": "var(--space-2)",
    "dropdown-padding": "var(--space-2)",
    "dropdown-offset": "var(--space-2)",
    "font-size": { "mobile": "var(--font-size-sm)", "desktop": "var(--font-size-base)" },
    "font-weight": "var(--font-weight-medium)",
    "font-weight-active": "var(--font-weight-semibold)",
    "border-radius": "var(--radius-md)",
    "dropdown-border-radius": "var(--radius-lg)",
    "animation-duration": "var(--duration-fast)",
    "animation-timing": "var(--easing-default)",
    "slide-duration": "var(--duration-slow)"
  },
  "elements": {
    "form": {
      "input-bg": "var(--color-surface)",
      "input-border": "var(--color-border)",
      "input-focus-border": "var(--color-primary)",
      "input-radius": "var(--radius-md)",
      "input-padding": "var(--space-3)",
      "input-disabled-bg": "var(--color-background-alt)",
      "input-placeholder-color": "var(--color-text-muted)",
      "label-color": "var(--color-text)",
      "label-size": "var(--font-size-sm)",
      "error-color": "var(--color-error)",
      "help-color": "var(--color-text-muted)",
      "primary-color": "var(--color-primary)",
      "primary-hover": "var(--color-primary-hover)",
      "success-color": "var(--color-success)",
      "warning-color": "var(--color-warning)",
      "text-color": "var(--color-text)",
      "text-muted": "var(--color-text-muted)",
      "bg-color": "var(--color-surface)",
      "bg-light": "var(--color-background-alt)",
      "border-color": "var(--color-border)",
      "focus-shadow": "0 0 0 3px var(--color-primary-light)",
      "title-size": "var(--font-size-xl)",
      "heading-size": "var(--font-size-lg)",
      "base-size": "var(--font-size-base)",
      "small-size": "var(--font-size-sm)",
      "tiny-size": "var(--font-size-xs)",
      "font-weight-bold": "var(--font-weight-semibold)",
      "font-weight-medium": "var(--font-weight-medium)",
      "line-height-relaxed": "var(--line-height-relaxed)",
      "spacing-lg": "var(--space-6)",
      "spacing-md": "var(--space-4)",
      "spacing-sm": "var(--space-3)",
      "spacing-xs": "var(--space-2)",
      "container-max-width": "720px",
      "container-padding": "var(--space-6)",
      "shadow": "var(--shadow-sm)",
      "transition": "all 0.2s ease",
      "button-padding-x": "var(--space-6)",
      "button-padding-y": "var(--space-3)",
      "button-radius": "var(--radius-md)",
      "checkbox-size": "1.25rem",
      "checkbox-radius": "var(--radius-sm)",
      "radio-size": "1.25rem",
      "star-empty-color": "var(--color-border)",
      "star-filled-color": "#fbbf24",
      "nps-button-height": "48px",
      "likert-min-width": "80px",
      "progress-height": "8px",
      "step-circle-size": "36px",
      "step-circle-size-mobile": "32px"
    }
  }
}
