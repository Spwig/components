{
  "component_type": "license_server_provider",
  "slug": "keygen",
  "name": "Keygen.sh",
  "version": "1.0.0",
  "description": "Popular license management platform with policy-based licensing, device tracking, and comprehensive analytics.",
  "author": "Spwig",
  "license": "Proprietary",
  "provider_key": "keygen",
  "class_name": "KeygenAdapter",
  "entry_point": "provider.py",
  "author_details": {
    "name": "Spwig",
    "email": "support@spwig.com",
    "website": "https://spwig.com"
  },
  "homepage_url": "https://keygen.sh",
  "support_url": "https://keygen.sh/docs/support",
  "api_docs_url": "https://keygen.sh/docs/api",
  "min_platform_version": "1.0.0",
  "capabilities": {
    "create_license": true,
    "validate_license": true,
    "activate_device": true,
    "deactivate_device": true,
    "suspend_license": true,
    "revoke_license": true,
    "webhooks": true,
    "policies": true,
    "usage_tracking": true,
    "floating_licenses": true,
    "offline_validation": false,
    "analytics": true
  },
  "features": [
    "Policy-based licensing system",
    "Device/machine activation tracking",
    "License key generation and validation",
    "Usage tracking and analytics",
    "Webhook notifications",
    "Floating license support",
    "License entitlements",
    "Multi-platform support (Windows, macOS, Linux)",
    "SDK available for major languages",
    "Comprehensive API"
  ],
  "dependencies": {
    "python": ">=3.10",
    "django": ">=4.2",
    "requests": ">=2.28.0"
  },
  "credential_schema": {
    "account_id": {
      "type": "text",
      "label": "Account ID",
      "help_text": "Your Keygen account ID (found in account URL: app.keygen.sh/accounts/YOUR_ACCOUNT_ID)",
      "required": true,
      "placeholder": "e.g., 1a2b3c4d-5e6f-7a8b-9c0d-1e2f3a4b5c6d"
    },
    "api_token": {
      "type": "password",
      "label": "Product Token",
      "help_text": "Product API token from Keygen dashboard (Settings → Tokens → Create Product Token)",
      "required": true,
      "secret": true,
      "placeholder": "••••••••••••••••"
    },
    "environment": {
      "type": "select",
      "label": "Environment",
      "help_text": "Use sandbox for testing before going live",
      "required": false,
      "choices": [
        ["production", "Production"],
        ["sandbox", "Sandbox"]
      ],
      "default": "production"
    }
  },
  "pricing": {
    "free_tier": {
      "licenses_per_month": 10,
      "features": [
        "Up to 10 licenses",
        "Basic policy support",
        "Standard API access",
        "Community support"
      ]
    },
    "paid_tiers": [
      {
        "name": "Indie",
        "price": "$29/month",
        "licenses_per_month": 1000,
        "features": [
          "Up to 1,000 licenses",
          "All policy features",
          "Webhooks",
          "Email support",
          "99.9% uptime SLA"
        ]
      },
      {
        "name": "Business",
        "price": "$99/month",
        "licenses_per_month": 10000,
        "features": [
          "Up to 10,000 licenses",
          "Priority support",
          "Advanced analytics",
          "Custom integrations",
          "99.95% uptime SLA"
        ]
      },
      {
        "name": "Enterprise",
        "price": "Contact sales",
        "licenses_per_month": "Unlimited",
        "features": [
          "Unlimited licenses",
          "Dedicated support",
          "Custom SLA",
          "On-premise option",
          "White-label available"
        ]
      }
    ]
  },
  "signup_url": "https://keygen.sh",
  "api_info": {
    "base_url": "https://api.keygen.sh/v1",
    "endpoints": {
      "licenses": "/accounts/{account_id}/licenses",
      "validate": "/accounts/{account_id}/licenses/actions/validate-key",
      "machines": "/accounts/{account_id}/machines",
      "policies": "/accounts/{account_id}/policies"
    },
    "documentation_url": "https://keygen.sh/docs/api"
  },
  "changelog": [
    {
      "version": "1.0.0",
      "date": "2026-01-21",
      "changes": [
        "Initial release",
        "Policy-based license management",
        "Device activation and tracking",
        "License validation",
        "Webhook support",
        "Floating license support",
        "Usage tracking",
        "Product mapping configuration",
        "Sandbox environment support"
      ]
    }
  ],
  "logo": "logo.png"
}
