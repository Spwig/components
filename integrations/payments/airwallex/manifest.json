  "credential_schema": {
    "test_mode": {
      "type": "boolean",
      "label": "Test Mode",
      "help_text": "Use demo credentials for testing. Automatically enforced in sandbox environments.",
      "required": true,
      "default": true
    },
    "test_client_id": {
      "type": "text",
      "label": "Demo Client ID",
      "help_text": "Your Airwallex Demo Client ID from Developer settings",
      "required": true,
      "placeholder": "e.g., demo_abc123def456",
      "group": "test_credentials"
    },
    "test_api_key": {
      "type": "password",
      "label": "Demo API Key",
      "help_text": "Your Airwallex Demo API Key from Developer settings",
      "required": true,
      "secret": true,
      "placeholder": "Enter your Demo API Key",
      "group": "test_credentials"
    },
    "test_webhook_secret": {
      "type": "password",
      "label": "Demo Webhook Secret",
      "help_text": "Optional: Demo webhook signature secret",
      "required": false,
      "secret": true,
      "placeholder": "Enter demo webhook secret (optional)",
      "group": "test_credentials"
    },
    "live_client_id": {
      "type": "text",
      "label": "Production Client ID",
      "help_text": "Your Airwallex Production Client ID. Optional - can be added later.",
      "required": false,
      "placeholder": "e.g., prod_abc123def456",
      "group": "live_credentials"
    },
    "live_api_key": {
      "type": "password",
      "label": "Production API Key",
      "help_text": "Your Airwallex Production API Key. Optional - can be added later.",
      "required": false,
      "secret": true,
      "placeholder": "Enter your Production API Key",
      "group": "live_credentials"
    },
    "live_webhook_secret": {
      "type": "password",
      "label": "Production Webhook Secret",
      "help_text": "Optional: Production webhook signature secret",
      "required": false,
      "secret": true,
      "placeholder": "Enter production webhook secret (optional)",
      "group": "live_credentials"
    },
    "auto_capture": {
      "type": "boolean",
      "label": "Auto Capture Payments",
      "help_text": "Automatically capture payments after authorization. Disable for manual capture workflow.",
      "required": false,
      "default": true
    },
    "payment_descriptor": {
      "type": "text",
      "label": "Statement Descriptor",
      "help_text": "Text that appears on customer's bank statement (max 22 characters)",
      "required": false,
      "max_length": 22,
      "placeholder": "YOUR STORE NAME"
    },
    "payment_method_types": {
      "type": "multiselect",
      "label": "Enabled Payment Methods",
      "help_text": "Select which payment methods to offer customers. Leave empty to show all methods available in your Airwallex account. Common types: card, wechatpay, alipaycn, applepay, googlepay, grabpay",
      "required": false,
      "options": [
        {"value": "card", "label": "Card Payments (Visa, Mastercard, Amex, etc.)"},
        {"value": "wechatpay", "label": "WeChat Pay"},
        {"value": "alipaycn", "label": "Alipay China"},
        {"value": "alipayhk", "label": "Alipay Hong Kong"},
        {"value": "applepay", "label": "Apple Pay"},
        {"value": "googlepay", "label": "Google Pay"},
        {"value": "grabpay", "label": "GrabPay"},
        {"value": "kakaopay", "label": "Kakao Pay"},
        {"value": "gcash", "label": "GCash"},
        {"value": "dana", "label": "DANA"},
        {"value": "tng", "label": "Touch 'n Go"},
        {"value": "truemoney", "label": "TrueMoney"}
      ]
    }
  },
  "webhooks": {
    "supported_events": [
      "payment_intent.succeeded",
      "payment_intent.failed",
      "payment_intent.requires_capture",
      "refund.received",
      "refund.accepted",
      "refund.settled",
      "refund.failed",
      "subscription.created",
      "subscription.active",
      "subscription.updated",
      "subscription.cancelled",
      "subscription.expired",
      "subscription.unpaid",
      "subscription.paused",
      "invoice.paid",
      "invoice.payment_failed",
      "invoice.upcoming"
    ],
    "verification_method": "hmac_sha256",
    "headers": ["x-timestamp", "x-signature"]
  },
  "signup_url": "https://www.airwallex.com/signup",
  "requires_restart": false,
  "requires_collectstatic": false,
  "post_install_commands": [],
  "setup_instructions": "setup_instructions.html",
  "logo": {
    "file": "logo.svg",
    "mime_type": "image/svg+xml"
  },
  "changelog": [
    {
      "version": "1.1.6",
      "date": "2026-03-01",
      "changes": [
        "Fixed credential validation failing for dual-credential (test/production) setup - base class now validates unprefixed credentials after selection",
        "Fixed subscription webhook signature verification to include x-timestamp in HMAC computation (security fix)",
        "Fixed cardholder name not being sent to Airwallex API during payment confirmation",
        "Fixed credential redaction to handle both prefixed (test_api_key, live_api_key) and unprefixed key formats",
        "Removed stale environment field from credential_schema property"
      ]
    },
    {
      "version": "1.1.4",
      "date": "2026-02-16",
      "changes": [
        "Implemented plugin architecture for frontend checkout integration - providers now ship their own JavaScript handlers",
        "Added checkout-handler.js for embedded payment integration using Airwallex SDK",
        "Added frontend manifest section with checkout_handler and sdk_dependencies",
        "Fixed cancel_url not being sent to Airwallex API (was received but not included in intent_data)",
        "Switched from hosted redirect to embedded checkout for better UX (customer stays on merchant site)",
        "Removed reliance on get_hosted_checkout_url() - now returns handler_config instead of checkout_url",
        "Added support for dynamic SDK loading based on merchant's configured provider"
      ]
    },
    {
      "version": "1.1.3",
      "date": "2026-02-16",
      "changes": [
        "Added configurable payment_method_types to allow merchants to select which payment methods to offer (card, Apple Pay, Google Pay, WeChat Pay, Alipay, GrabPay, etc.)",
        "Added customer name to payment intent creation for hosted checkout display",
        "Added fallback for last_name when customer only has single name",
        "Removed hardcoded 'card' payment method - now shows all available methods by default"
      ]
    },
    {
      "version": "1.1.2",
      "date": "2026-02-11",
      "changes": [
        "Fixed test_connection() using /account endpoint that requires admin permissions — now uses /pa/config/payment_method_types which works with scoped API keys",
        "Added error logging to test_connection() failures"
      ]
    },
    {
      "version": "1.1.1",
      "date": "2026-02-09",
      "changes": [
        "Fixed missing request_id in create_payment_intent_for_checkout() when no order_id provided",
        "Fixed missing request_id in cancel_payment_intent(), capture_payment(), refund_payment(), and confirm_payment_intent()",
        "Fixed charge() and authorize() passing empty string as order_id",
        "Added create_checkout_session() implementation for hosted checkout flow"
      ]
    },
    {
      "version": "1.1.0",
      "date": "2026-02-04",
      "changes": [
        "Added payment orchestration support for checkout flow",
        "New create_payment_intent_for_checkout() method for hosted/embedded checkout",
        "New retrieve_payment_intent() method for status polling",
        "New confirm_payment_intent() method for 3DS confirmation",
        "New cancel_payment_intent() method for intent cancellation",
        "Added get_hosted_checkout_url() helper for redirect flow",
        "Support for PaymentIntent lifecycle management"
      ]
    },
    {
      "version": "1.0.0",
      "date": "2025-01-14",
      "changes": [
        "Initial release with full payment processing support",
        "Support for 160+ payment methods globally",
        "Multi-currency processing with competitive FX rates",
        "Webhook integration for real-time payment notifications",
        "Full and partial refund capabilities",
        "3D Secure authentication support"
      ]
    }
  ],
  "pricing_info": {
    "model": "transaction_based",
    "notes": "Competitive transaction fees. Partner rates available. Contact Airwallex for pricing details."
  },
  "regions": {
    "supported": ["global"],
    "restricted": [],
    "notes": "Available globally with 160+ local payment methods across 130+ countries"
  },
  "compliance": {
    "pci_dss": true,
    "certifications": ["PCI DSS Level 1", "SOC 2 Type II"],
    "data_residency": ["multi_region"]
  }
}
