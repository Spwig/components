  "changelog": [
    {
      "version": "1.2.2",
      "date": "2026-07-04",
      "changes": [
        "Fixed 400 'payment_intent_invalid_parameter' from Stripe when enabled_payment_methods contained wallet aliases (apple_pay, google_pay) — these are not valid Stripe payment_method_types values; they surface automatically on PaymentElement when card is enabled and the device supports them. New _filter_stripe_payment_method_types() strips wallet aliases before calling Stripe.",
        "When no valid payment_method_types remain after filtering, fall back to Stripe's recommended automatic_payment_methods: {enabled: true, allow_redirects: 'if_required'}. Applies to both integrated PaymentElement and hosted Checkout Session modes.",
        "Include the Stripe error message on failure responses so the orchestrator surfaces the real reason to the storefront instead of the generic 'Payment intent creation failed' fallback."
      ]
    },
    {
      "version": "1.2.1",
      "date": "2026-06-30",
      "changes": [
        "Embedded PaymentIntent path: return empty string instead of null for checkout_url / client_secret / provider_intent_id so the orchestrator's non-nullable columns accept the row without coalescing. Pairs with shop 1.5.6, which adds defensive coalescing for any provider that still returns None."
      ]
    },
    {
      "version": "1.2.0",
      "date": "2026-03-31",
      "changes": [
        "Accept payment_method_types from orchestration service for per-country method filtering",
        "Hosted checkout: pass payment_method_types to Stripe Checkout Session when specified",
        "Integrated checkout: use explicit payment_method_types instead of automatic_payment_methods when specified",
        "Added **kwargs to create_payment_intent_for_checkout for forward-compatible parameter passing"
      ]
    },
    {
      "version": "1.1.2",
      "date": "2026-03-11",
      "changes": [
        "Fixed webhook URL in setup instructions (was /payment-providers/webhook/{slug}/, corrected to /webhooks/payments/{slug}/)",
        "Fixed timezone.utc AttributeError in subscription event timestamp parsing"
      ]
    },
    {
      "version": "1.1.1",
      "date": "2026-03-01",
      "changes": [
        "Fixed critical NameError in integrated checkout (undefined customer_country variable)",
        "Simplified credential initialization - removed redundant workaround now that base class handles dual-credential selection",
        "Fixed redact_credentials to handle dual-credential format (test_/live_ prefixed keys)",
        "Fixed webhook verification to fail-secure when webhook secret is not configured",
        "Removed stale environment field from credential_schema property",
        "Restored subscription_provider.py for subscription framework compatibility",
        "Fixed invoice charge type-checking for safe null handling"
      ]
    },
    {
      "version": "1.1.0",
      "date": "2026-02-17",
      "changes": [
        "Implemented plugin architecture for frontend checkout integration",
        "Added checkout-handler.js for embedded payment using Stripe Elements Payment Element",
        "Added frontend manifest section with checkout_handler and sdk_dependencies",
        "Enhanced integrated mode to return handler_config for embedded checkout",
        "Customers stay on merchant site throughout payment (no redirect)",
        "Automatic SDK loading based on configured provider",
        "Unified Payment Element supports cards, Apple Pay, Google Pay, and BNPL automatically",
        "Built-in 3D Secure handling and validation",
        "Full backward compatibility - existing modes continue working"
      ]
    },
    {
      "version": "1.0.0",
      "date": "2026-02-09",
      "changes": [
        "Initial release with full payment processing support",
        "Support for cards, digital wallets, BNPL, and bank transfers",
        "135+ currency support with automatic zero-decimal handling",
        "Stripe Checkout (hosted) and Payment Intents (integrated) support",
        "Webhook integration with signature verification",
        "Full and partial refund capabilities",
        "3D Secure authentication support",
        "Authorize and capture workflow"
      ]
    }
  ],
  "pricing_info": {
    "model": "transaction_based",
    "notes": "Standard pricing: 2.9% + 30c per successful card charge. International cards +1.5%. Volume discounts available. Visit stripe.com/pricing for details."
  },
