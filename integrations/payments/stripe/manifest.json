  "credential_schema": {
    "test_mode": {
      "type": "boolean",
      "label": "Test Mode",
      "help_text": "Use test credentials. Automatically enforced in sandbox environments.",
      "required": true,
      "default": true
    },
    "test_publishable_key": {
      "type": "text",
      "label": "Test Publishable Key",
      "help_text": "Your Stripe Test Publishable Key (starts with pk_test_)",
      "required": true,
      "placeholder": "pk_test_...",
      "group": "test_credentials"
    },
    "test_secret_key": {
      "type": "password",
      "label": "Test Secret Key",
      "help_text": "Your Stripe Test Secret Key (starts with sk_test_)",
      "required": true,
      "secret": true,
      "placeholder": "sk_test_...",
      "group": "test_credentials"
    },
    "test_webhook_secret": {
      "type": "password",
      "label": "Test Webhook Secret",
      "help_text": "Optional: Test webhook signing secret (starts with whsec_)",
      "required": false,
      "secret": true,
      "placeholder": "whsec_...",
      "group": "test_credentials"
    },
    "live_publishable_key": {
      "type": "text",
      "label": "Live Publishable Key",
      "help_text": "Your Stripe Live Publishable Key (starts with pk_live_). Optional - can be added later.",
      "required": false,
      "placeholder": "pk_live_...",
      "group": "live_credentials"
    },
    "live_secret_key": {
      "type": "password",
      "label": "Live Secret Key",
      "help_text": "Your Stripe Live Secret Key (starts with sk_live_). Optional - can be added later.",
      "required": false,
      "secret": true,
      "placeholder": "sk_live_...",
      "group": "live_credentials"
    },
    "live_webhook_secret": {
      "type": "password",
      "label": "Live Webhook Secret",
      "help_text": "Optional: Live webhook signing secret (starts with whsec_)",
      "required": false,
      "secret": true,
      "placeholder": "whsec_...",
      "group": "live_credentials"
    }
  },
  "webhooks": {
    "supported_events": [
      "payment_intent.succeeded",
      "payment_intent.payment_failed",
      "charge.refunded",
      "charge.refund.updated",
      "checkout.session.completed",
      "customer.subscription.created",
