  "credential_schema": {
    "api_key": {
      "type": "password",
      "label": "API Key",
      "help_text": "Your Adyen API key from Customer Area -> Developers -> API credentials",
      "required": true,
      "secret": true,
      "placeholder": "Enter your API Key"
    },
    "merchant_account": {
      "type": "text",
      "label": "Merchant Account",
      "help_text": "Your Adyen merchant account name from the Customer Area",
      "required": true,
      "placeholder": "e.g., YourCompanyECOM"
    },
    "client_key": {
      "type": "text",
      "label": "Client Key",
      "help_text": "Client-side key for the Adyen Drop-in/Components (from API credentials page)",
      "required": true,
      "placeholder": "e.g., live_XXXXXXXXXXXXXXXX"
    },
    "hmac_key": {
      "type": "password",
      "label": "HMAC Key",
      "help_text": "Optional: HMAC key for webhook signature verification. Found in Developers -> Webhooks -> HMAC Key",
      "required": false,
      "secret": true,
      "placeholder": "Enter HMAC key for webhook verification (optional)"
    },
    "environment": {
      "type": "select",
      "label": "Environment",
      "help_text": "Use Test for development, Live for real transactions",
      "required": true,
      "default": "test",
      "options": [
        {
          "value": "test",
          "label": "Test/Sandbox"
        },
        {
          "value": "live",
          "label": "Live/Production"
        }
      ]
    },
    "live_endpoint_prefix": {
      "type": "text",
      "label": "Live Endpoint Prefix",
      "help_text": "Required for live environment. Found in Customer Area -> Settings -> API URLs. This is the prefix before '-checkout-live.adyenpayments.com'",
      "required": false,
      "placeholder": "e.g., 1797a841fbb37ca7-YourCompany"
    }
  },
  "webhooks": {
    "supported_events": [
      "AUTHORISATION",
      "CAPTURE",
      "CANCELLATION",
      "REFUND",
      "REFUND_FAILED"
    ],
    "verification_method": "hmac_sha256",
    "headers": [
      "hmac-signature"
    ]
  },
  "signup_url": "https://www.adyen.com/signup",
  "requires_restart": false,
  "requires_collectstatic": false,
  "post_install_commands": [],
  "setup_instructions": "setup_instructions.html",
  "logo": {
    "file": "logo.svg",
    "mime_type": "image/svg+xml"
  },
  "changelog": [
    {
      "version": "1.0.0",
      "date": "2026-02-09",
      "changes": [
        "Initial release with full payment processing support",
        "Support for 250+ payment methods globally",
        "Adyen Drop-in and Sessions API integration",
        "HMAC-SHA256 webhook signature verification",
        "Full and partial refund capabilities",
        "3D Secure 2 authentication support",
        "Multi-currency processing across 150+ currencies",
        "Authorize and capture workflow support"
      ]
    }
  ],
  "pricing_info": {
    "model": "transaction_based",
    "notes": "Processing fees vary by payment method and region. Volume discounts available. Contact Adyen for pricing details."
  },
  "regions": {
    "supported": [
      "global"
    ],
    "restricted": [],
    "notes": "Available globally across 40+ countries with 250+ local payment methods"
  },
  "compliance": {
    "pci_dss": true,
    "certifications": [
      "PCI DSS Level 1",
      "SOC 2"
    ],
    "data_residency": [
      "multi_region"
    ]
  }
}
