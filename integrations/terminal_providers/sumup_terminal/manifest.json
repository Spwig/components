{
  "component_type": "terminal_provider",
  "slug": "sumup_terminal",
  "name": "SumUp Terminal",
  "version": "1.0.0",
  "description": "Accept card-present payments using SumUp Solo card readers via cloud API. Push payments to SumUp hardware from your POS.",
  "author": "Spwig",
  "author_details": {
    "name": "Spwig",
    "email": "support@spwig.com",
    "website": "https://spwig.com"
  },
  "homepage_url": "https://www.sumup.com/",
  "support_url": "https://developer.sumup.com/terminal-payments/cloud-api",
  "license": "AGPL-3.0",
  "min_platform_version": "2.0.0",
  "requires_platform": "2.x",
  "python_version": ">=3.10",
  "django_version": ">=4.2,<5.0",
  "python_packages": [
    "requests>=2.28.0"
  ],
  "platform_components": {
    "pos_app": ">=1.0.0"
  },
  "provider_key": "sumup_terminal",
  "entry_point": "provider",
  "class_name": "SumUpTerminalProvider",
  "capabilities": {
    "connection_tokens": false,
    "reader_discovery": true,
    "locations": false,
    "refunds": true,
    "integration_mode": "cloud",
    "payment_methods": ["card_present", "contactless"],
    "reader_actions": ["collect_payment", "cancel_payment"],
    "features": {
      "cloud_communication": true,
      "local_communication": false,
      "tap_to_pay": true,
      "smart_readers": true,
      "tipping": true
    }
  },
  "supported_readers": [
    {
      "type": "solo",
      "name": "SumUp Solo",
      "category": "smart_reader",
      "connection": "cloud",
      "description": "Standalone card reader with touchscreen display"
    },
    {
      "type": "solo_lite",
      "name": "SumUp Solo Lite",
      "category": "card_reader",
      "connection": "cloud",
      "description": "Compact card reader"
    }
  ],
  "credential_schema": {
    "api_key": {
      "type": "password",
      "label": "API Key",
      "help_text": "Your SumUp API key. Generate in the SumUp Developer Dashboard.",
      "required": true,
      "placeholder": "sup_sk_..."
    },
    "merchant_code": {
      "type": "text",
      "label": "Merchant Code",
      "help_text": "Your SumUp merchant code. Found in your SumUp profile settings.",
      "required": true,
      "placeholder": "MXXX..."
    }
  },
  "settings_schema": {
    "affiliate_app_id": {
      "type": "text",
      "label": "Affiliate App ID",
      "help_text": "Your SumUp affiliate key (app_id) for Cloud API transactions. Created in the Developer Dashboard under Affiliate Keys.",
      "required": true,
      "placeholder": ""
    }
  },
  "signup_url": "https://www.sumup.com/en-us/signup/",
  "requires_restart": false,
  "requires_collectstatic": false,
  "post_install_commands": [],
  "setup_instructions": "setup_instructions.html",
  "logo": {
    "file": "logo.svg",
    "mime_type": "image/svg+xml"
  },
  "changelog": [
    {
      "version": "1.0.0",
      "date": "2026-02-09",
      "changes": [
        "Initial release with SumUp Cloud API terminal support",
        "Cloud-based payment initiation via Readers Checkout API",
        "Status polling for payment completion",
        "Reader pairing and discovery",
        "Checkout termination (cancel) support",
        "Full and partial refund support",
        "Support for Solo and Solo Lite readers"
      ]
    }
  ],
  "pricing_info": {
    "model": "transaction_based",
    "notes": "SumUp charges a flat per-transaction fee (varies by region, typically 1.69% in EU). No monthly fees."
  },
  "regions": {
    "supported": ["US", "GB", "IE", "DE", "FR", "IT", "ES", "PT", "NL", "AT", "BE", "LU", "FI", "SE", "DK", "NO", "PL", "CZ", "HU", "CH", "BR", "CL", "CO", "AU"],
    "restricted": [],
    "notes": "Available in 30+ countries across Europe, the Americas, and Australia."
  },
  "compliance": {
    "pci_dss": true,
    "certifications": ["PCI DSS Level 1", "EMV"],
    "data_residency": ["multi_region"]
  }
}
